<Window x:Class="CurrencyExchangeClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="720" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Currency Exchange Office"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <Border Grid.Row="1"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Padding="15"
                CornerRadius="8"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Username:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="UsernameTextBox" Text="demo" Height="28" Margin="0,0,10,0"/>

                <TextBlock Grid.Column="2" Text="Password:" VerticalAlignment="Center"/>
                <PasswordBox Grid.Column="3" x:Name="PasswordInputBox" Password="demo" Height="28" Margin="0,0,10,0"/>

                <Button Grid.Column="4" Content="Login" Height="30" Margin="0,0,10,0" Click="LoginButton_Click"/>
                <Button Grid.Column="5" Content="Register" Height="30" Margin="0,0,10,0" Click="RegisterButton_Click"/>

                <TextBlock Grid.Column="6"
                           x:Name="AccountStatusTextBlock"
                           Text="Not logged in"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Padding="20"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="From currency:" Margin="0,0,10,10"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="FromCurrencyComboBox" Height="28" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="To currency:" Margin="0,0,10,10"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ToCurrencyComboBox" Height="28" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Amount:" Margin="0,0,10,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="AmountTextBox" Height="28" Text="100" Margin="0,0,0,10"/>

                <Button Grid.Row="3" Grid.Column="1"
                        Content="Convert"
                        Width="120"
                        Height="35"
                        HorizontalAlignment="Left"
                        Click="ConvertButton_Click"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="ResultTextBlock"
                   Text="Result will be displayed here."
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,20,0,15"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Transaction history">
                <ListBox x:Name="HistoryListBox"/>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Account balances">
                <ListBox x:Name="BalancesListBox"/>
            </GroupBox>
        </Grid>
    </Grid>
</Window>